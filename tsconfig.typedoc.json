{
  // Dedicated TypeScript project for TypeDoc. It only needs to resolve modules
  // well enough to read the public API + TSDoc comments (TypeDoc runs with
  // `skipErrorChecking`), so it isn't used for typechecking.
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"],
    "jsx": "preserve",
    // Resolve the Nuxt-module alias to the bundled default client (what
    // src/module.ts falls back to), so the reference documents the real
    // authClient/AuthClient types instead of `any`.
    "baseUrl": ".",
    "paths": {
      "#convex/auth-client": ["./src/runtime/better-auth/vue/client.ts"]
    }
  },
  "include": [
    "src/runtime/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}
