{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ]
    },
    "convex": {
      "command": "npx",
      "args": [
        "-y",
        "convex@latest",
        "mcp",
        "start",
        "--project-dir",
        "website"
      ]
    },
    "nuxt-docs": {
      "type": "http",
      "url": "https://nuxt.com/mcp"
    },
    "better-auth-docs": {
      "url": "https://mcp.better-auth.com/mcp",
      "type": "https"
    },
    "polar": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.polar.sh/mcp/polar-sandbox"
      ]
    }
  }
}
